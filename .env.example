# Decide — environment variable reference
# Copy to .env and fill in real values. Do not commit .env.

# --- Server-side (Vercel functions) ---
ANTHROPIC_API_KEY=
# Firecrawl REST API key for the live research phase (api/researchPhase.js).
# Must be a cloud key (starts with "fc-"). Pull it with: npx firecrawl env --overwrite
FIRECRAWL_API_KEY=
# Optional: override the Firecrawl API base URL (e.g. for self-hosted instances).
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# Resend API key for beta feedback emails — get yours at resend.com
RESEND_API_KEY=
# Your email address to receive beta tester feedback
FEEDBACK_RECIPIENT_EMAIL=
# Verified-domain sender for feedback emails (e.g. feedback@yourdomain.com).
# Leave blank to use the Resend sandbox (onboarding@resend.dev — only delivers to the Resend
# account owner). To switch: verify a domain at resend.com → Domains, add the DNS records, then
# set this to feedback@<your-verified-domain> in Vercel env + local .env. No code change needed.
FEEDBACK_FROM_EMAIL=
# Shared secret gating /api/feedback. Leave BLANK to disable the gate (open endpoint).
# When set, the client must send the same value — see EXPO_PUBLIC_FEEDBACK_SHARED_SECRET below.
FEEDBACK_SHARED_SECRET=
# Internal QA test account (a beta_tester in constants/betaTesters.js). Reference creds only —
# NOT read by app code, NOT EXPO_PUBLIC (stays out of the bundle). Type them into the login screen.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=

# --- Client-side (must use EXPO_PUBLIC_ prefix) ---
EXPO_PUBLIC_API_BASE_URL=
GOOGLE_PLACES_API_KEY=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_OPENWEATHER_API_KEY=
EXPO_PUBLIC_TICKETMASTER_API_KEY=
EXPO_PUBLIC_EVENTBRITE_API_KEY=
EXPO_PUBLIC_NPS_API_KEY=
EXPO_PUBLIC_RIDB_API_KEY=
EXPO_PUBLIC_OPENROUTE_API_KEY=
# Must match FEEDBACK_SHARED_SECRET. Sent as the x-feedback-secret header on feedback POSTs.
# NOTE: EXPO_PUBLIC vars are baked into the app bundle and extractable — this raises the bar
# against casual abuse, it is not a true secret. Blank = no header sent (gate stays open).
EXPO_PUBLIC_FEEDBACK_SHARED_SECRET=

# --- Firebase (client) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
